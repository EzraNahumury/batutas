# Master wallet holding the ~100 CELO to distribute. KEEP SECRET. Throwaway only.
FUNDER_PRIVATE_KEY=

# Celo mainnet RPC (default = public forno node).
RPC_URL=https://forno.celo.org
CHAIN_ID=42220

# Batutas game contract on Celo mainnet.
CONTRACT_ADDRESS=0x18e3B8359ad9f6C926B53ED2D432CCdc576c3Ebf

# Tunables
WALLET_COUNT=100            # how many wallets to generate / use
AMOUNT_PER_WALLET_CELO=1    # CELO sent to each wallet by distribute.js
DEPOSIT_CELO=0.001          # CELO deposited per wallet per tick (1 batuta)
CONCURRENCY=20              # parallel txs per batch

# Master wallet that funds the wallets. KEEP SECRET. Throwaway only.
# 500 wallets x AMOUNT_PER_WALLET_CELO (+ gas). At 0.01 => ~5 CELO + gas.
FUNDER_PRIVATE_KEY=

# Celo mainnet RPC (default = public forno node).
RPC_URL=https://forno.celo.org
CHAIN_ID=42220

# Batutas game contract on Celo mainnet.
CONTRACT_ADDRESS=0x18e3B8359ad9f6C926B53ED2D432CCdc576c3Ebf

# Tunables
WALLET_COUNT=500            # 500 unique wallets => DAU 500 (1 deposit each/day)
AMOUNT_PER_WALLET_CELO=0.01 # CELO sent to each wallet by distribute.js (covers ~3 ticks)
DEPOSIT_CELO=0.001          # CELO deposited per wallet per tick (1 batuta)
CONCURRENCY=20              # parallel txs per batch

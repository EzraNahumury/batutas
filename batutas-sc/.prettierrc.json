{
  "plugins": ["prettier-plugin-solidity"],
  "printWidth": 100,
  "singleQuote": false,
  "overrides": [
    {
      "files": "*.sol",
      "options": {
        "tabWidth": 4,
        "printWidth": 100
      }
    },
    {
      "files": "*.ts",
      "options": {
        "tabWidth": 2
      }
    }
  ]
}

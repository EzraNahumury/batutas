{
  "name": "batutas-sc",
  "version": "0.1.0",
  "description": "Provably-fair on-chain Rock-Paper-Scissors smart contracts for BATUTAS (Celo Mainnet, MiniPay-ready).",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "lint": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write 'contracts/**/*.sol' 'test/**/*.ts' 'scripts/**/*.ts'",
    "format:check": "prettier --check 'contracts/**/*.sol' 'test/**/*.ts' 'scripts/**/*.ts'",
    "coverage": "hardhat coverage",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network celoSepolia",
    "deploy:celo": "hardhat run scripts/deploy.ts --network celo",
    "deploy:token:sepolia": "hardhat run scripts/deploy-token.ts --network celoSepolia",
    "deploy:token:celo": "hardhat run scripts/deploy-token.ts --network celo"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^16.4.7",
    "hardhat": "^2.22.17",
    "prettier": "^3.8.4",
    "prettier-plugin-solidity": "^2.3.1",
    "solhint": "^6.2.1"
  },
  "dependencies": {
    "batutas-sdk": "^0.2.0"
  }
}
